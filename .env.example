# Root .env — developer-local tooling credentials for Claude Code commands.
# These are NEVER deployed and NEVER committed. Copy to .env and fill in.

# --- Jira variants only (.claude/commands/jira/) ---
# JIRA_BASE_URL=https://yourorg.atlassian.net
# JIRA_EMAIL=you@example.com
# JIRA_API_TOKEN=
# JIRA_ACCOUNT_ID=
# JIRA_PROJECT_KEY=PROJ
# JIRA_BOARD_ID=

# --- Tempo time logging (/jira/log-time) ---
# TEMPO_API_TOKEN=
# TEMPO_ISSUE_ID=
# TEMPO_ACCOUNT_ID=
# GIT_AUTHOR_NAME=
