# Root .env — developer-local tooling credentials for Claude Code commands.
# These are NEVER deployed and NEVER committed. Copy to .env and fill in.

# --- Jira (required for all ticket lifecycle commands) ---
# JIRA_BASE_URL=https://yourorg.atlassian.net
# JIRA_EMAIL=you@example.com
# JIRA_API_TOKEN=                # Create at: id.atlassian.com → Security → API tokens
# JIRA_ACCOUNT_ID=               # Find at: id.atlassian.com, or from any Jira ticket you're assigned to
#                                #   via API: curl -u $JIRA_EMAIL:$JIRA_API_TOKEN "$JIRA_BASE_URL/rest/api/3/myself" | python3 -c "import json,sys; print(json.load(sys.stdin)['accountId'])"
# JIRA_PROJECT_KEY=PROJ          # The project key prefix on ticket IDs (e.g. PROJ from PROJ-123).
#                                #   Find it: open any ticket in the project — it's the letters before the dash.
#                                #   Or via API: curl -u $JIRA_EMAIL:$JIRA_API_TOKEN "$JIRA_BASE_URL/rest/api/3/issue/<any-ticket-id>" | python3 -c "import json,sys; print(json.load(sys.stdin)['fields']['project']['key'])"
# JIRA_BOARD_ID=                 # The numeric board ID for the project's Kanban/Scrum board.
#                                #   Find it: open the board in Jira — the ID is in the URL: /jira/software/projects/<KEY>/boards/<ID>
#                                #   Or via API: curl -u $JIRA_EMAIL:$JIRA_API_TOKEN "$JIRA_BASE_URL/rest/agile/1.0/board?projectKeyOrId=<PROJ>" | python3 -c "import json,sys; [print(b['id'], b['name']) for b in json.load(sys.stdin)['values']]"

# --- Tempo time logging (/log-time) ---
# TEMPO_API_TOKEN=               # Create at: app.tempo.io → Settings → API Integration
# TEMPO_ISSUE_ID=                # Numeric Jira issue ID to log time against (not the key — the internal id field)
# TEMPO_ACCOUNT_ID=              # Your Atlassian account ID — same as JIRA_ACCOUNT_ID above
# GIT_AUTHOR_NAME=               # Your git author name as it appears in commits (run: git log -1 --format='%an')
