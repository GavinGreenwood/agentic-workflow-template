# Root .env — developer-local tooling credentials for Claude Code commands.
# These are NEVER deployed and NEVER committed. Copy to .env and fill in.

# --- GitHub Project board (scripts/set-project-status.sh) ---
# Drives the board transitions in /capture, /pickup, /pr, /pr-action-review.
# Find the number in the project URL:
#   user-owned:  github.com/users/<you>/projects/<NUMBER>
#   org-owned:   github.com/orgs/<org>/projects/<NUMBER>
# The gh token needs the read-write `project` scope: gh auth refresh -s project
# GH_PROJECT_OWNER=your-github-login-or-org
# GH_PROJECT_NUMBER=
# GH_PROJECT_OWNER_TYPE=user   # 'user' or 'org'

# --- Jira variants only (.claude/commands/jira/) ---
# JIRA_BASE_URL=https://yourorg.atlassian.net
# JIRA_EMAIL=you@example.com
# JIRA_API_TOKEN=
# JIRA_ACCOUNT_ID=
# JIRA_PROJECT_KEY=PROJ
# JIRA_BOARD_ID=

# --- Tempo time logging (/jira/log-time) ---
# TEMPO_API_TOKEN=
# TEMPO_ISSUE_ID=
# TEMPO_ACCOUNT_ID=
# GIT_AUTHOR_NAME=
